# ============================================================
# Nowakowski Web — environment variables
# ============================================================
# Copy this file to `.env.local` for local development.
# On Vercel, configure each variable for the right
# environments (Production / Preview / Development).
# ============================================================

# ----- Public -----
# Canonical site URL. Leave empty on preview to use VERCEL_URL automatically.
# Production: https://nowakowski-web.fr
NEXT_PUBLIC_SITE_URL=

# ----- Resend (contact form) -----
# Resend API key. Use separate prod/preview keys
# to avoid polluting deliverability.
RESEND_API_KEY=
# Sender address (must be verified in Resend).
CONTACT_EMAIL_FROM=
# Recipient address for contact form messages.
# Tip: use a test alias (e.g. contact+preview@…) on preview.
CONTACT_EMAIL_TO=

# ----- Sanity -----
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# ----- Free audit (Google PageSpeed Insights) -----
# Google Cloud API key with PageSpeed Insights API enabled.
PAGESPEED_API_KEY=

# ----- SEO -----
# Google Search Console verification code (production only).
GOOGLE_SITE_VERIFICATION=

# ----- SEO automation (optional, local scripts only) -----
# OAuth client JSON downloaded from Google Cloud Console (Search Console API).
GSC_OAUTH_SECRETS_FILE=
# GSC domain property (sc-domain: prefix required).
GSC_SITE_URL=sc-domain:nowakowski-web.fr
# DataForSEO account (prepaid credit, pay-per-call).
DATAFORSEO_USERNAME=
DATAFORSEO_PASSWORD=
