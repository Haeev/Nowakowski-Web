# ============================================================
# Nowakowski Web — variables d'environnement
# ============================================================
# Copier ce fichier en `.env.local` pour le dev local.
# Sur Vercel, configurer chaque variable pour les bons
# environnements (Production / Preview / Development).
# ============================================================

# ----- Public -----
# URL canonique du site. Laisser vide en preview pour utiliser
# automatiquement VERCEL_URL.
# Production : https://nowakowski-web.fr
NEXT_PUBLIC_SITE_URL=

# ----- Resend (formulaire de contact) -----
# Clé API Resend. Utiliser des clés différentes prod/preview
# pour ne pas polluer la délivrabilité.
RESEND_API_KEY=
# Adresse expéditrice (doit être validée dans Resend).
CONTACT_EMAIL_FROM=
# Adresse destinataire des messages du formulaire.
# Conseil : un alias de test (ex: contact+preview@…) en preview.
CONTACT_EMAIL_TO=

# ----- Sanity -----
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# ----- SEO -----
# Code de vérification Google Search Console (production uniquement).
GOOGLE_SITE_VERIFICATION=
